<% layout('/layouts/boilerplate') -%>

<!-- Hero Section -->
<section class="wl-home-hero">
  <div class="wl-home-hero-bg"></div>
  <div class="container h-100">
    <div class="row h-100 align-items-center">
      <div class="col-12 col-lg-7">

        <p class="wl-home-eyebrow">
          <span></span> The World Awaits
        </p>

        <h1 class="wl-home-title">
          Extraordinary places.<br>
          <em>Unforgettable</em> stays.
        </h1>

        <p class="wl-home-subtitle">
          WonderLust curates the world's most remarkable properties —
          from cliffside villas to hidden forest retreats. Your next chapter starts here.
        </p>

        <div class="wl-home-actions">
          <a href="/listing" class="wl-home-btn-primary">
            <i class="fa-solid fa-compass"></i> Explore Listings
          </a>
          <a href="/listing/new" class="wl-home-btn-secondary">
            <i class="fa-solid fa-plus"></i> List Your Place
          </a>
        </div>

        <!-- Trust Bar -->
        <div class="wl-home-trust">
          <div class="wl-trust-item">
            <span class="wl-trust-number">500+</span>
            <span class="wl-trust-label">Properties</span>
          </div>
          <div class="wl-trust-divider"></div>
          <div class="wl-trust-item">
            <span class="wl-trust-number">50+</span>
            <span class="wl-trust-label">Countries</span>
          </div>
          <div class="wl-trust-divider"></div>
          <div class="wl-trust-item">
            <span class="wl-trust-number">4.9★</span>
            <span class="wl-trust-label">Avg Rating</span>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<!-- Features Section -->
<section class="wl-features-section">
  <div class="container">

    <div class="wl-features-header text-center">
      <p class="wl-features-eyebrow">Why WonderLust</p>
      <h2 class="wl-features-title">Travel redefined</h2>
      <p class="wl-features-subtitle">We believe every journey deserves a remarkable home base</p>
    </div>

    <div class="row g-4 mt-2">

      <div class="col-12 col-md-4">
        <div class="wl-feature-card">
          <div class="wl-feature-icon">
            <i class="fa-solid fa-gem"></i>
          </div>
          <h3 class="wl-feature-title">Curated Quality</h3>
          <p class="wl-feature-desc">
            Every listing is handpicked and verified. We set the bar high so you never have to second-guess your stay.
          </p>
        </div>
      </div>

      <div class="col-12 col-md-4">
        <div class="wl-feature-card wl-feature-card--dark">
          <div class="wl-feature-icon wl-feature-icon--gold">
            <i class="fa-solid fa-earth-americas"></i>
          </div>
          <h3 class="wl-feature-title wl-feature-title--light">Global Reach</h3>
          <p class="wl-feature-desc wl-feature-desc--light">
            From the valleys of Tuscany to the beaches of Goa — discover properties in over 50 countries worldwide.
          </p>
        </div>
      </div>

      <div class="col-12 col-md-4">
        <div class="wl-feature-card">
          <div class="wl-feature-icon">
            <i class="fa-solid fa-shield-halved"></i>
          </div>
          <h3 class="wl-feature-title">Trusted & Safe</h3>
          <p class="wl-feature-desc">
            Secure listings, transparent pricing, and a community built on trust. Your peace of mind is our priority.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- How It Works -->
<section class="wl-how-section">
  <div class="container">
    <div class="row align-items-center g-5">

      <!-- Left Text -->
      <div class="col-12 col-lg-5">
        <p class="wl-how-eyebrow">Simple & Fast</p>
        <h2 class="wl-how-title">How it works</h2>
        <p class="wl-how-subtitle">
          Getting started with WonderLust takes minutes. Browse, pick, and experience the extraordinary.
        </p>
        <a href="/listing" class="wl-btn-primary mt-4 d-inline-flex">
          Start Exploring <i class="fa-solid fa-arrow-right ms-2"></i>
        </a>
      </div>

      <!-- Right Steps -->
      <div class="col-12 col-lg-7">
        <div class="wl-steps">

          <div class="wl-step">
            <div class="wl-step-number">01</div>
            <div class="wl-step-content">
              <h4 class="wl-step-title">Browse Listings</h4>
              <p class="wl-step-desc">Explore our curated collection of extraordinary properties across the globe.</p>
            </div>
          </div>

          <div class="wl-step">
            <div class="wl-step-number">02</div>
            <div class="wl-step-content">
              <h4 class="wl-step-title">Choose Your Stay</h4>
              <p class="wl-step-desc">Find the perfect match — filter by location, price, and style to suit your trip.</p>
            </div>
          </div>

          <div class="wl-step">
            <div class="wl-step-number">03</div>
            <div class="wl-step-content">
              <h4 class="wl-step-title">List Your Place</h4>
              <p class="wl-step-desc">Have a property to share? Add it in minutes and reach travellers worldwide.</p>
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

<!-- CTA Section -->
<section class="wl-cta-section">
  <div class="container">
    <div class="wl-cta-card">
      <div class="wl-cta-glow"></div>
      <div class="row align-items-center g-4">
        <div class="col-12 col-lg-8">
          <p class="wl-cta-eyebrow">Ready to begin?</p>
          <h2 class="wl-cta-title">Your next great stay is waiting</h2>
          <p class="wl-cta-subtitle">
            Join thousands of travellers discovering the world's most remarkable places through WonderLust.
          </p>
        </div>
        <div class="col-12 col-lg-4 d-flex gap-3 flex-wrap justify-content-lg-end">
          <a href="/listing" class="wl-cta-btn-primary">
            <i class="fa-solid fa-compass"></i> Explore Now
          </a>
          <a href="/listing/new" class="wl-cta-btn-secondary">
            List a Place
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
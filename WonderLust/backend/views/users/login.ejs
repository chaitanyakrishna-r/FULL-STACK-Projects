<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - WonderLust</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-header">
            <div class="auth-logo">
                <i class="fa-solid fa-wind"></i>
            </div>
            <h2>Welcome Back</h2>
            <p>Log in to your <strong>WonderLust</strong> account</p>
        </div>

        <% if (errorMsg) { %>
            <div class="auth-error">
                <i class="fa-solid fa-circle-exclamation"></i> <%= errorMsg %>
            </div>
        <% } %>

        <form action="/login" method="post" class="auth-form">
            <div class="form-group">
                <label>Username</label>
                <div class="input-wrap">
                    <i class="fa-solid fa-user"></i>
                    <input type="text" name="username" placeholder="Enter your username">
                </div>
            </div>
            <div class="form-group">
                <label>Email</label>
                <div class="input-wrap">
                    <i class="fa-solid fa-envelope"></i>
                    <input type="email" name="email" placeholder="sample@gmail.com">
                </div>
            </div>
            <div class="form-group">
                <label>Password</label>
                <div class="input-wrap">
                    <i class="fa-solid fa-lock"></i>
                    <input type="password" name="password" placeholder="Enter your password">
                </div>
            </div>
            <button type="submit" class="auth-btn">Log In</button>
        </form>

        <p class="auth-switch">Don't have an account? <a href="/signup">Sign Up</a></p>
    </div>
</div>

</body>
</html>
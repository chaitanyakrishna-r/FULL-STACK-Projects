
<% if(listing.reviews.length === 0) { %>
    <div class="wl-no-reviews">
        <i class="fa-regular fa-face-sad-tear"></i>
        <p>No reviews yet. Be the first to review!</p>
    </div>
<% } else { %>
    <h4 class="wl-reviews-heading">
        <i class="fa-solid fa-star"></i> All Reviews
        <span class="wl-reviews-count"><%= listing.reviews.length %></span>
    </h4>

    <% for(let review of listing.reviews) { %>
        <div class="wl-review-card">

            <!-- Review Header -->
            <div class="wl-review-header">
                <div class="wl-reviewer-avatar">
                    <%= review.author.username[0].toUpperCase() %>
                </div>
                <div class="wl-reviewer-info">
                    <span class="wl-reviewer-name"><%= review.author.username %></span>
                    <div class="wl-review-stars">
                        <% for(let i = 1; i <= 5; i++) { %>
                            <i class="fa-<%= i <= review.rating ? 'solid' : 'regular' %> fa-star"></i>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- Comment -->
            <p class="wl-review-comment"><%= review.comment %></p>

            <!-- Actions - only for review owner -->
            <% if(currentUser && review.author._id.equals(currentUser._id)) { %>
                <div class="wl-review-actions">
                    <a href="/listing/<%= listing.id %>/reviews/<%= review._id %>/edit" class="wl-review-edit-btn">
                        <i class="fa-solid fa-pen"></i> Edit
                    </a>
                    <form action="/listing/<%= listing.id %>/reviews/<%= review._id %>?_method=DELETE" method="post">
                        <button type="submit" class="wl-review-delete-btn">
                            <i class="fa-solid fa-trash"></i> Delete
                        </button>
                    </form>
                </div>
            <% } %>

        </div>
    <% } %>
<% } %>
<script>
function confirmDelete() {
    return confirm("Are you sure you want to delete this review?");
}
</script>